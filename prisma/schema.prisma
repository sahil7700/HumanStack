generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// -----------------------------------------------------------------------------
// USER & PROFILE
// -----------------------------------------------------------------------------

model User {
  id        String   @id @default(uuid())
  clerkId   String   @unique // Auth mapped from Clerk
  email     String   @unique
  role      Role     @default(USER)
  
  profile   Profile? // One-to-one relationship for onboarding data
  workoutPlans WorkoutPlan[]
  sessions  WorkoutSession[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Role {
  USER
  ADMIN
  COACH
}

// Stores onboarding data for AI generation
model Profile {
  id              String   @id @default(uuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  age             Int?
  gender          String?
  heightCm        Float?
  weightKg        Float?
  bodyFatPercent  Float?
  fitnessLevel    String?  // Beginner, Intermediate, Advanced
  
  injuries        String?  // e.g., "Lower back pain, impinged right shoulder"
  postureIssues   String?  // e.g., "Forward head posture, anterior pelvic tilt"
  
  equipment       String?  // e.g., "Full Gym", "Dumbbells only", "Bodyweight"
  daysPerWeek     Int?
  workoutDuration Int?     // In minutes
  
  goals           String[] // Ordered list of goals: ["fat_loss", "posture", "strength"]
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// -----------------------------------------------------------------------------
// WORKOUT ARCHITECTURE
// -----------------------------------------------------------------------------

// A multi-week plan generated by the AI
model WorkoutPlan {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  title       String   // e.g., "Phase 1: Foundation & Posture Correction"
  focus       String   // e.g., "Hypertrophy + Core Stability"
  startDate   DateTime
  endDate     DateTime?
  active      Boolean  @default(true)
  
  sessions    WorkoutSession[] // The individual daily workouts generated for this plan
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// A single day's workout (e.g., "Push Day")
model WorkoutSession {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  planId        String?
  plan          WorkoutPlan? @relation(fields: [planId], references: [id], onDelete: SetNull)
  
  name          String   // e.g., "Upper Body Power"
  scheduledFor  DateTime // When the user is supposed to do it
  completedAt   DateTime? // When they actually finished
  
  energyScore   Int?     // User input 1-10 before/after workout
  readinessScore Int?    // Computed or user inputted readiness 
  
  exercises     WorkoutExercise[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// -----------------------------------------------------------------------------
// EXERCISE CATALOG & TRACKING
// -----------------------------------------------------------------------------

// Global catalog of exercises
model Exercise {
  id              String   @id @default(uuid())
  name            String   @unique
  description     String?
  targetMuscle    String?
  synergists      String[]
  movementPattern String?  // e.g., "Horizontal Push", "Hip Hinge"
  videoUrl        String?
  
  workoutInstances WorkoutExercise[]
}

// An exercise mapped to a specific workout session
model WorkoutExercise {
  id            String   @id @default(uuid())
  sessionId     String
  session       WorkoutSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  
  exerciseId    String
  exercise      Exercise @relation(fields: [exerciseId], references: [id])
  
  order         Int      // Order within the session
  notes         String?  // AI or coach notes (e.g., "Focus on slow eccentrics")
  
  sets          Set[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// A specific set within a workout exercise
model Set {
  id                String   @id @default(uuid())
  workoutExerciseId String
  workoutExercise   WorkoutExercise @relation(fields: [workoutExerciseId], references: [id], onDelete: Cascade)
  
  setNumber         Int
  
  // Target generated by AI
  targetReps        Int?
  targetWeight      Float?
  targetRpe         Float?   // Rate of Perceived Exertion
  restTimeSeconds   Int?
  
  // Actual performed by user
  actualReps        Int?
  actualWeight      Float?
  actualRpe         Float?
  
  completed         Boolean  @default(false)

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}
